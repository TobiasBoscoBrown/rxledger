{
  "name": "rxledger",
  "version": "1.0.0",
  "private": true,
  "description": "A regulated prescription backbone \u2014 demo of the CollectiveOS Senior Backend Engineer stack (NestJS \u00b7 PostgreSQL \u00b7 Zod \u00b7 Turborepo \u00b7 AWS-ready).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "dev": "npm --workspace @rxledger/api run start:dev",
    "db:migrate": "npm --workspace @rxledger/api run db:migrate",
    "db:seed": "npm --workspace @rxledger/api run db:seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.8"
}
