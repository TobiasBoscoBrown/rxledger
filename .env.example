# --- Server ---
NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# --- Auth ---
# Must be >= 32 chars. Generate: openssl rand -base64 48
JWT_SECRET=dev-only-change-me-dev-only-change-me-32+
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=1209600

# --- Crypto / KMS ---
# 32-byte AES-256 master key, base64. Generate: openssl rand -base64 32
# In production this is an AWS KMS key id; the LocalKmsService is dev/test only.
KMS_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- Database (Postgres / RDS) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rxledger

# --- Integrations ---
PHARMACY_WEBHOOK_SECRET=fake-secret

# --- Rate limiting (backed by Redis/ElastiCache in production) ---
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
